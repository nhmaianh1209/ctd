# Copy this to .env and fill in real values
# DO NOT commit .env to git

# Local admin account (used for testing before MSAL is ready)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT signing secret — change to a random string in production
JWT_SECRET=local-dev-secret-change-me
TOKEN_TTL_HOURS=8

# Microsoft SSO (Azure AD) — fill in when ready, then update auth.py
# MSAL_CLIENT_ID=your-azure-client-id
# MSAL_TENANT_ID=your-azure-tenant-id
# ALLOWED_DOMAIN=coteccons.vn

# PostgreSQL
DB_NAME=ctd
DB_USER=ctd
DB_PASSWORD=ctd
