{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/llmwiki-validate.py\" ] && exec python3 \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/llmwiki-validate.py\" claude-hook || exit 0",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/harness-events.py\" ] && exec python3 \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/harness-events.py\" stop || exit 0",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/harness-events.py\" audit 2>/dev/null || true",
            "timeout": 10
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/harness-events.py\" session 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/harness-events.py\" docs 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/harness/poc-vendor-neutral/bin/harness-events.py\" session-end 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ]
  }
}