async function renderMonth(){
  document.getElementById('monthLabel').textContent = `${MONTHS_VI[currentMonth]} ${currentYear}`;
  document.getElementById('calBody').innerHTML = '<div class="empty" style="grid-column:1/-1;"><span class="spinner"></span></div>';
  try{
    monthCourses = await api_loadCoursesByMonth(toYM(currentYear,currentMonth));
    drawCalendar();
  }catch(e){
    console.error(e);
    document.getElementById('calBody').innerHTML = '<div class="empty" style="grid-column:1/-1;">Lỗi tải dữ liệu. Refresh lại trang.</div>';
  }
}

function drawCalendar(){
  const firstDay = new Date(currentYear,currentMonth,1);
  let offset = (firstDay.getDay()+6)%7;
  const daysInMonth = new Date(currentYear,currentMonth+1,0).getDate();
  const prevDaysInMonth = new Date(currentYear,currentMonth,0).getDate();
  const filtered = monthCourses.filter(c=>{
    if(filterMode==='all') return true;
    return c.visibility===filterMode;
  });
  const byDay = {};
  filtered.forEach(c=>{
    (c.dates||[]).forEach(iso=>{
      const {y,m,d} = parseISO(iso);
      if(y===currentYear && m===currentMonth){
        (byDay[d] = byDay[d]||[]).push(c);
      }
    });
  });
  let html = '';
  const totalCells = Math.ceil((offset+daysInMonth)/7)*7;
  for(let i=0;i<totalCells;i++){
    const dayCol = i%7;
    const isWeekend = dayCol>=5;
    let cls = 'day';
    if(isWeekend) cls += ' weekend';
    let dayNum, isOther=false;
    if(i<offset){ dayNum = prevDaysInMonth - offset + 1 + i; cls+=' other-month'; isOther=true; }
    else if(i>=offset+daysInMonth){ dayNum = i - offset - daysInMonth + 1; cls+=' other-month'; isOther=true; }
    else{
      dayNum = i - offset + 1;
      const isToday = (dayNum===today.getDate() && currentMonth===today.getMonth() && currentYear===today.getFullYear());
      if(isToday) cls+=' today';
    }
    let inner = `<span class="daynum">${dayNum}</span>`;
    if(!isOther){
      const list = byDay[dayNum]||[];
      const show = list.slice(0,3);
      show.forEach(c=>{
        const label = c.short_name || c.name;
        const catCls = `cat-${c.category||'technical'}`;
        const lock = c.visibility==='internal' ? '<span class="lock">🔒</span>' : '';
        inner += `<div class="pill ${catCls}" title="${esc(c.name)}">${esc(label)}${lock}</div>`;
      });
      if(list.length>3) inner += `<div class="more-tag">+${list.length-3} khác</div>`;
    }
    const dataAttr = isOther ? '' : `data-day="${dayNum}"`;
    html += `<div class="${cls}" ${dataAttr}>${inner}</div>`;
  }
  document.getElementById('calBody').innerHTML = html;
  document.querySelectorAll('.day[data-day]').forEach(el=>{
    el.addEventListener('click', ()=>openDayModal(parseInt(el.dataset.day)));
  });
}

function openDayModal(day){
  selectedDay = day;
  const ymd = toISO(currentYear,currentMonth,day);
  document.getElementById('dayModalTitle').textContent =
    `Ngày ${day} · ${MONTHS_VI[currentMonth]} ${currentYear}`;
  const list = monthCourses.filter(c=>(c.dates||[]).includes(ymd));
  const CAT_ORDER = {mandatory:1, technical:2, language:3, 'soft-skills':4};
  list.sort((a,b)=>(CAT_ORDER[a.category]||99)-(CAT_ORDER[b.category]||99));
  const body = document.getElementById('dayModalBody');
  if(list.length===0){
    body.innerHTML = '<div class="empty">Chưa có khoá học nào trong ngày này.<br/>Click <b>+ Thêm khoá học</b> để tạo mới.</div>';
  }else{
    body.innerHTML = list.map(c=>renderCourseCard(c)).join('');
    body.querySelectorAll('[data-edit]').forEach(b=>b.addEventListener('click', ()=>openFormModal(b.dataset.edit)));
    body.querySelectorAll('[data-del]').forEach(b=>b.addEventListener('click', ()=>deleteCourse(b.dataset.del)));
  }
  document.getElementById('dayModal').classList.add('show');
}

function renderCourseCard(c){
  const regText = {
    link: `Đăng ký tại link${c.registration_link?': <a href="'+esc(c.registration_link)+'" target="_blank" style="color:var(--teal);">'+esc(c.registration_link)+'</a>':''}`,
    email: 'Email đăng ký được gửi cho đối tượng tham gia',
    assigned: 'Theo danh sách được chỉ định',
    other: 'Khác: ' + esc(c.registration_other||'')
  }[c.registration_type] || '—';
  const visBadge = c.visibility==='public'
    ? '<span class="badge badge-public">🌐 Công khai</span>'
    : '<span class="badge badge-internal">🔒 Nội bộ</span>';
  const catBadge = `<span class="badge cat-${c.category||'technical'}">${categoryLabel(c.category)}</span>`;
  const trainer = c.trainer_type==='internal'
    ? `Nội bộ${c.trainer_name?': '+esc(c.trainer_name):''}`
    : `Bên ngoài${c.trainer_name?': '+esc(c.trainer_name):''}`;
  return `
    <div class="day-course">
      <div class="day-course-head">
        <div class="day-course-title">${esc(c.name)} ${catBadge} ${visBadge}</div>
      </div>
      <div class="day-course-meta">
        <b>Hình thức:</b> ${(c.formats||[]).map(esc).join(', ')}<br/>
        <b>Đối tượng:</b> ${esc(c.target||'')}<br/>
        <b>Giảng viên:</b> ${trainer}<br/>
        <b>Thời lượng:</b> ${c.duration_hours||0} giờ &nbsp;·&nbsp; <b>Ngày:</b> ${formatDatesGrouped(c.dates)}<br/>
        <b>Cách đăng ký:</b> ${regText}<br/>
        ${c.requirements?`<b>Điều kiện:</b> ${esc(c.requirements)}<br/>`:''}
        <span style="color:var(--gray-500);font-size:11px;">Tạo bởi: ${esc(c.created_by||'')}${c.updated_by&&c.updated_by!==c.created_by?` · Sửa cuối: ${esc(c.updated_by)}`:''}</span>
      </div>
      <div class="day-course-actions">
        <button class="btn-secondary btn-sm" data-edit="${c.id}">✏️ Sửa</button>
        <button class="btn-danger btn-sm" data-del="${c.id}">🗑 Xoá</button>
      </div>
    </div>`;
}

document.getElementById('btnAddCourse').addEventListener('click', ()=>openFormModal(null));

function renderMiniCal(){
  document.getElementById('miniLabel').textContent = `${MONTHS_VI[miniMonth]} ${miniYear}`;
  const firstDay = new Date(miniYear, miniMonth, 1);
  let offset = (firstDay.getDay()+6)%7;
  const daysInMonth = new Date(miniYear, miniMonth+1, 0).getDate();
  const prevDaysInMonth = new Date(miniYear, miniMonth, 0).getDate();
  let html='';
  const totalCells = Math.ceil((offset+daysInMonth)/7)*7;
  for(let i=0;i<totalCells;i++){
    const dayCol = i%7;
    const isWeekend = dayCol>=5;
    let cls = 'mini-day';
    if(isWeekend) cls+=' we';
    let dayNum, isOther=false;
    if(i<offset){ dayNum = prevDaysInMonth - offset + 1 + i; cls+=' other'; isOther=true; }
    else if(i>=offset+daysInMonth){ dayNum = i - offset - daysInMonth + 1; cls+=' other'; isOther=true; }
    else{ dayNum = i - offset + 1; }
    let attr = '';
    if(!isOther){
      const iso = toISO(miniYear, miniMonth, dayNum);
      if(selectedDates.includes(iso)) cls+=' selected';
      attr = `data-iso="${iso}"`;
    }
    html += `<div class="${cls}" ${attr}>${dayNum}</div>`;
  }
  document.getElementById('miniCalBody').innerHTML = html;
  document.querySelectorAll('#miniCalBody .mini-day[data-iso]').forEach(el=>{
    el.addEventListener('click', ()=>{
      const iso = el.dataset.iso;
      const idx = selectedDates.indexOf(iso);
      if(idx>=0) selectedDates.splice(idx,1);
      else selectedDates.push(iso);
      selectedDates.sort();
      renderMiniCal();
      updateMiniSummary();
    });
  });
}
function updateMiniSummary(){
  const el = document.getElementById('miniSummary');
  if(selectedDates.length===0){
    el.innerHTML = 'Chưa chọn ngày nào.';
    return;
  }
  const groups = {};
  selectedDates.forEach(iso=>{
    const {y,m,d} = parseISO(iso);
    const key = `${y}-${pad2(m+1)}`;
    (groups[key]=groups[key]||[]).push(d);
  });
  const keys = Object.keys(groups).sort();
  let lines = keys.map(k=>{
    const [y,m] = k.split('-');
    const monthName = MONTHS_VI[parseInt(m)-1];
    return `<span class="month-line"><b>${monthName} ${y}:</b> ${groups[k].join(', ')}</span>`;
  }).join('');
  el.innerHTML = `<button type="button" class="clear-btn" id="clearDatesBtn">Xoá tất cả</button>
    Đã chọn <b>${selectedDates.length} ngày</b>:<br/>${lines}`;
  document.getElementById('clearDatesBtn').addEventListener('click', ()=>{
    selectedDates = [];
    renderMiniCal();
    updateMiniSummary();
  });
}
document.getElementById('miniPrev').addEventListener('click', ()=>{
  miniMonth--; if(miniMonth<0){miniMonth=11;miniYear--;}
  renderMiniCal();
});
document.getElementById('miniNext').addEventListener('click', ()=>{
  miniMonth++; if(miniMonth>11){miniMonth=0;miniYear++;}
  renderMiniCal();
});

function openFormModal(courseId){
  const form = document.getElementById('courseForm');
  form.reset();
  document.getElementById('branchLink').style.display='none';
  document.getElementById('branchOther').style.display='none';
  document.getElementById('branchTrainerInt').style.display='none';
  document.getElementById('branchTrainerExt').style.display='none';
  selectedDates = [];
  miniYear = currentYear;
  miniMonth = currentMonth;

  if(courseId){
    const c = monthCourses.find(x=>x.id===courseId);
    if(!c) return;
    document.getElementById('formTitle').textContent='Sửa khoá học';
    form.docId.value = c.id;
    form.name.value = c.name||'';
    form.short_name.value = c.short_name||'';
    if(c.category){
      const r = form.querySelector(`input[name=category][value="${c.category}"]`);
      if(r) r.checked=true;
    }
    (c.formats||[]).forEach(f=>{
      const cb = form.querySelector(`input[name=formats][value="${f}"]`);
      if(cb) cb.checked=true;
    });
    form.target.value = c.target||'';
    if(c.trainer_type){
      const r = form.querySelector(`input[name=trainer_type][value="${c.trainer_type}"]`);
      if(r) r.checked=true;
      if(c.trainer_type==='internal'){
        document.getElementById('branchTrainerInt').style.display='block';
        form.trainer_name_internal.value = c.trainer_name||'';
      }else{
        document.getElementById('branchTrainerExt').style.display='block';
        form.trainer_name_external.value = c.trainer_name||'';
      }
    }
    form.duration_hours.value = c.duration_hours||'';
    selectedDates = [...(c.dates||[])];
    if(selectedDates.length>0){
      const {y,m} = parseISO(selectedDates[0]);
      miniYear = y; miniMonth = m;
    }
    if(c.registration_type){
      const r = form.querySelector(`input[name=registration_type][value="${c.registration_type}"]`);
      if(r) r.checked=true;
      if(c.registration_type==='link'){
        document.getElementById('branchLink').style.display='block';
        form.registration_link.value = c.registration_link||'';
      }
      if(c.registration_type==='other'){
        document.getElementById('branchOther').style.display='block';
        form.registration_other.value = c.registration_other||'';
      }
    }
    form.requirements.value = c.requirements||'';
    if(c.visibility){
      const v = form.querySelector(`input[name=visibility][value="${c.visibility}"]`);
      if(v) v.checked=true;
    }
  }else{
    document.getElementById('formTitle').textContent='Thêm khoá học';
    form.docId.value = '';
    if(selectedDay){ selectedDates = [toISO(currentYear,currentMonth,selectedDay)]; }
    form.querySelector('input[name=visibility][value="public"]').checked=true;
  }
  renderMiniCal();
  updateMiniSummary();
  document.getElementById('formModal').classList.add('show');
}

document.querySelectorAll('input[name=registration_type]').forEach(r=>{
  r.addEventListener('change', ()=>{
    document.getElementById('branchLink').style.display = (r.checked && r.value==='link') ? 'block':'none';
    document.getElementById('branchOther').style.display = (r.checked && r.value==='other') ? 'block':'none';
    if(r.checked && r.value!=='link') document.getElementById('branchLink').style.display='none';
    if(r.checked && r.value!=='other') document.getElementById('branchOther').style.display='none';
  });
});
document.querySelectorAll('input[name=trainer_type]').forEach(r=>{
  r.addEventListener('change', ()=>{
    document.getElementById('branchTrainerInt').style.display = (r.checked && r.value==='internal') ? 'block':'none';
    document.getElementById('branchTrainerExt').style.display = (r.checked && r.value==='external') ? 'block':'none';
    if(r.checked && r.value!=='internal') document.getElementById('branchTrainerInt').style.display='none';
    if(r.checked && r.value!=='external') document.getElementById('branchTrainerExt').style.display='none';
  });
});

document.getElementById('courseForm').addEventListener('submit', async e=>{
  e.preventDefault();
  const form = e.target;
  const fd = new FormData(form);
  const formats = fd.getAll('formats');
  if(formats.length===0){ toast('Vui lòng chọn ít nhất 1 hình thức','error'); return; }
  if(selectedDates.length===0){ toast('Vui lòng chọn ít nhất 1 ngày','error'); return; }
  if(!fd.get('category')){ toast('Vui lòng chọn phân loại','error'); return; }
  if(!fd.get('trainer_type')){ toast('Vui lòng chọn giảng viên','error'); return; }

  const trainerType = fd.get('trainer_type');
  const trainerName = (trainerType==='internal' ? fd.get('trainer_name_internal') : fd.get('trainer_name_external')) || '';

  const sortedDates = [...selectedDates].sort();
  const monthsSet = new Set();
  sortedDates.forEach(iso=>{
    const {y,m} = parseISO(iso);
    monthsSet.add(`${y}-${pad2(m+1)}`);
  });

  const data = {
    name: fd.get('name').trim(),
    short_name: (fd.get('short_name')||'').trim(),
    category: fd.get('category'),
    formats,
    target: fd.get('target').trim(),
    trainer_type: trainerType,
    trainer_name: trainerName.trim(),
    duration_hours: parseFloat(fd.get('duration_hours'))||0,
    dates: sortedDates,
    months: [...monthsSet].sort(),
    registration_type: fd.get('registration_type'),
    registration_link: fd.get('registration_link')||'',
    registration_other: fd.get('registration_other')||'',
    requirements: (fd.get('requirements')||'').trim(),
    visibility: fd.get('visibility')
  };

  const btn = document.getElementById('saveBtn');
  btn.disabled=true; btn.innerHTML='<span class="spinner"></span>';
  try{
    const docId = fd.get('docId');
    if(docId){
      await api_updateCourse(docId, data);
      toast('Đã cập nhật khoá học','success');
    }else{
      await api_createCourse(data);
      toast('Đã thêm khoá học','success');
    }
    closeAllModals();
    await renderMonth();
    if(selectedDay) openDayModal(selectedDay);
  }catch(ex){
    console.error(ex);
    toast('Lỗi: '+ex.message,'error');
  }finally{
    btn.disabled=false; btn.textContent='Lưu khoá học';
  }
});

async function deleteCourse(id){
  if(!confirm('Xoá khoá học này? Hành động không thể hoàn tác.')) return;
  try{
    await api_deleteCourse(id);
    toast('Đã xoá','success');
    await renderMonth();
    if(selectedDay) openDayModal(selectedDay);
  }catch(ex){
    toast('Lỗi xoá: '+ex.message,'error');
  }
}

/* ===== Export Excel ===== */
let exportMode = null;
document.getElementById('btnExport').addEventListener('click', ()=>{
  document.getElementById('exportCurrentDesc').textContent = `${MONTHS_VI[currentMonth]} ${currentYear}`;
  document.getElementById('rangeFrom').value = toYM(currentYear,currentMonth);
  document.getElementById('rangeTo').value = toYM(currentYear,currentMonth);
  document.querySelectorAll('.export-option').forEach(o=>o.style.borderColor='var(--gray-200)');
  document.querySelector('#exportRangeOpt .range-inputs').style.display='none';
  exportMode = null;
  document.getElementById('btnDoExport').style.display='none';
  document.getElementById('exportModal').classList.add('show');
});
document.querySelectorAll('.export-option').forEach(opt=>{
  opt.addEventListener('click', ()=>{
    document.querySelectorAll('.export-option').forEach(x=>x.style.borderColor='var(--gray-200)');
    opt.style.borderColor='var(--teal)';
    exportMode = opt.dataset.mode;
    if(exportMode==='range'){
      document.querySelector('#exportRangeOpt .range-inputs').style.display='grid';
    }else{
      document.querySelector('#exportRangeOpt .range-inputs').style.display='none';
    }
    document.getElementById('btnDoExport').style.display='inline-flex';
  });
});

document.getElementById('btnDoExport').addEventListener('click', async ()=>{
  const btn = document.getElementById('btnDoExport');
  btn.disabled=true; btn.innerHTML='<span class="spinner"></span>';
  try{
    let courses = [];
    let fname = 'ctd-training-calendar';
    if(exportMode==='current'){
      courses = await api_loadCoursesByMonth(toYM(currentYear,currentMonth));
      fname += `_${toYM(currentYear,currentMonth)}`;
    }else if(exportMode==='range'){
      const from = document.getElementById('rangeFrom').value;
      const to = document.getElementById('rangeTo').value;
      if(!from || !to){ toast('Vui lòng chọn đủ tháng bắt đầu và kết thúc','error'); return; }
      if(from>to){ toast('Tháng bắt đầu phải <= tháng kết thúc','error'); return; }
      courses = await api_loadCoursesByMonthRange(from, to);
      fname += `_${from}_to_${to}`;
    }else if(exportMode==='all'){
      courses = await api_loadAllCourses();
      fname += `_all`;
    }
    fname += '_export.xlsx';
    if(courses.length===0){ toast('Không có dữ liệu để xuất','error'); return; }
    courses.sort((a,b)=>{
      const da = (a.dates||['9999'])[0];
      const db = (b.dates||['9999'])[0];
      return da<db?-1:da>db?1:0;
    });
    const rows = courses.map(c=>({
      'Tên khoá học': c.name||'',
      'Tên ngắn': c.short_name||'',
      'Phân loại': categoryLabel(c.category),
      'Hình thức': (c.formats||[]).join(', '),
      'Đối tượng': c.target||'',
      'Loại giảng viên': c.trainer_type==='internal'?'Nội bộ':c.trainer_type==='external'?'Bên ngoài':'',
      'Tên giảng viên': c.trainer_name||'',
      'Thời lượng (giờ)': c.duration_hours||0,
      'Các ngày': formatDatesGrouped(c.dates),
      'Cách đăng ký': {link:'Đăng ký tại link',email:'Email gửi cho đối tượng',assigned:'Theo danh sách chỉ định',other:'Khác'}[c.registration_type]||'',
      'Link / Ghi chú đăng ký': c.registration_link||c.registration_other||'',
      'Điều kiện tham gia': c.requirements||'',
      'Phân quyền': c.visibility==='public'?'Công khai':'Nội bộ',
      'Tạo bởi': c.created_by||'',
      'Ngày tạo': c.created_at?.toDate?c.created_at.toDate().toLocaleString('vi-VN'):'',
      'Sửa cuối bởi': c.updated_by||'',
      'Ngày sửa cuối': c.updated_at?.toDate?c.updated_at.toDate().toLocaleString('vi-VN'):''
    }));
    const ws = XLSX.utils.json_to_sheet(rows);
    const cols = Object.keys(rows[0]);
    ws['!cols'] = cols.map(k=>({wch: Math.min(40, Math.max(k.length, ...rows.map(r=>String(r[k]||'').length))+2)}));
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Training Calendar');
    XLSX.writeFile(wb, fname);
    toast(`Đã xuất ${courses.length} khoá học`,'success');
    closeAllModals();
  }catch(ex){
    console.error(ex);
    toast('Lỗi xuất file: '+ex.message,'error');
  }finally{
    btn.disabled=false; btn.innerHTML='Tải file';
  }
});

document.querySelectorAll('[data-close]').forEach(b=>b.addEventListener('click', closeAllModals));
document.querySelectorAll('.modal-backdrop').forEach(bd=>{
  bd.addEventListener('click', e=>{ if(e.target===bd) closeAllModals(); });
});
function closeAllModals(){
  document.querySelectorAll('.modal-backdrop').forEach(m=>m.classList.remove('show'));
}

function toast(msg, type=''){
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(()=>t.remove(), 3500);
}
</script>
