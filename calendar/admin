<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0" />
<title>Admin · Lịch đào tạo Coteccons Academy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lexend+Deca:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  :root{
    --navy:#0A2540; --navy-2:#143A5C;
    --teal:#14B8A6; --teal-dark:#0F8C7E; --teal-light:#CCFBF1;
    --gray-50:#F8FAFC; --gray-100:#F1F5F9; --gray-200:#E2E8F0;
    --gray-300:#CBD5E1; --gray-500:#64748B; --gray-700:#334155;
    --red:#DC2626; --green:#16A34A;
    --cat-tech-bg:#DBEAFE; --cat-tech-text:#1E40AF; --cat-tech-dot:#3B82F6;
    --cat-mand-bg:#FED7AA; --cat-mand-text:#9A3412; --cat-mand-dot:#EA580C;
    --cat-lang-bg:#D1FAE5; --cat-lang-text:#065F46; --cat-lang-dot:#10B981;
    --cat-soft-bg:#CFFAFE; --cat-soft-text:#155E75; --cat-soft-dot:#06B6D4;
    --shadow-sm:0 1px 2px rgba(10,37,64,.06);
    --shadow:0 4px 16px rgba(10,37,64,.08);
    --shadow-lg:0 12px 32px rgba(10,37,64,.16);
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  html,body{font-family:'Lexend Deca',system-ui,sans-serif;color:var(--navy);background:var(--gray-50);}
  button{font-family:inherit;cursor:pointer;border:none;}
  input,select,textarea{font-family:inherit;font-size:14px;}

  header.topbar{background:var(--navy);color:#fff;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;box-shadow:var(--shadow);position:sticky;top:0;z-index:50;}
  .brand{display:flex;align-items:center;gap:12px;font-weight:600;}
  .brand .logo{width:32px;height:32px;border-radius:8px;background:var(--teal);display:flex;align-items:center;justify-content:center;font-weight:700;}
  .brand .sub{font-size:11px;color:var(--gray-300);font-weight:300;letter-spacing:1px;text-transform:uppercase;}
  .user-info{display:flex;align-items:center;gap:12px;font-size:13px;}
  .user-info .email{color:var(--gray-300);}
  .btn-logout{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.2);padding:6px 14px;border-radius:6px;font-size:12px;transition:.2s;}
  .btn-logout:hover{background:rgba(255,255,255,.1);}

  .login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;}
  .login-card{background:#fff;border-radius:16px;box-shadow:var(--shadow-lg);padding:40px;width:100%;max-width:420px;}
  .login-card h1{font-size:22px;margin-bottom:8px;}
  .login-card .lead{color:var(--gray-500);font-size:14px;margin-bottom:28px;}
  .login-card label{display:block;font-size:12px;font-weight:500;color:var(--gray-700);margin-bottom:6px;}
  .login-card input{width:100%;padding:12px 14px;border:1px solid var(--gray-200);border-radius:8px;margin-bottom:16px;transition:.2s;}
  .login-card input:focus{outline:none;border-color:var(--teal);box-shadow:0 0 0 3px rgba(20,184,166,.15);}
  .btn-primary{background:var(--teal);color:#fff;padding:12px 20px;border-radius:8px;font-weight:500;font-size:14px;width:100%;transition:.2s;}
  .btn-primary:hover{background:var(--teal-dark);}
  .btn-primary:disabled{background:var(--gray-300);cursor:not-allowed;}
  .err{color:var(--red);font-size:12px;margin-top:8px;min-height:18px;}

  main.app{display:none;padding:24px;max-width:1400px;margin:0 auto;}
  main.app.visible{display:block;}
  .toolbar{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:16px;margin-bottom:20px;}
  .toolbar-left{display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
  .toolbar-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
  .month-nav{display:flex;align-items:center;gap:12px;}
  .month-nav h2{font-size:22px;font-weight:600;min-width:180px;text-align:center;}
  .nav-btn{background:#fff;border:1px solid var(--gray-200);width:36px;height:36px;border-radius:8px;font-size:16px;color:var(--navy);transition:.2s;}
  .nav-btn:hover{background:var(--gray-100);}
  .filter-pills{display:flex;gap:8px;background:#fff;padding:4px;border-radius:10px;border:1px solid var(--gray-200);}
  .filter-pills button{padding:6px 14px;border-radius:7px;font-size:13px;color:var(--gray-500);background:transparent;}
  .filter-pills button.active{background:var(--navy);color:#fff;}
  .btn-export{background:#fff;border:1px solid var(--gray-200);padding:8px 14px;border-radius:8px;font-size:13px;color:var(--navy);display:inline-flex;align-items:center;gap:6px;transition:.2s;}
  .btn-export:hover{background:var(--gray-100);border-color:var(--teal);}

  .calendar{background:#fff;border-radius:14px;overflow:hidden;box-shadow:var(--shadow-sm);border:1px solid var(--gray-200);}
  .cal-head,.cal-body{display:grid;grid-template-columns:repeat(7,1fr);}
  .cal-head>div{padding:12px 8px;text-align:center;font-size:12px;font-weight:600;color:var(--gray-500);text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--gray-200);background:var(--gray-50);}
  .cal-head>div.weekend{color:var(--teal);}
  .day{min-height:118px;padding:8px;border-right:1px solid var(--gray-100);border-bottom:1px solid var(--gray-100);cursor:pointer;transition:.15s;position:relative;display:flex;flex-direction:column;gap:4px;}
  .day:hover{background:var(--gray-50);}
  .day:nth-child(7n){border-right:none;}
  .day.other-month{background:#FAFBFC;color:var(--gray-300);cursor:default;}
  .day.other-month:hover{background:#FAFBFC;}
  .day.today .daynum{background:var(--teal);color:#fff;}
  .daynum{display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:50%;font-size:13px;font-weight:500;}
  .day.weekend .daynum{color:var(--teal);}
  .day.other-month .daynum{color:var(--gray-300);}

  .pill{font-size:11px;padding:3px 8px;border-radius:6px;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:4px;}
  .pill::before{content:"";width:5px;height:5px;border-radius:50%;flex-shrink:0;}
  .pill.cat-technical{background:var(--cat-tech-bg);color:var(--cat-tech-text);}
  .pill.cat-technical::before{background:var(--cat-tech-dot);}
  .pill.cat-mandatory{background:var(--cat-mand-bg);color:var(--cat-mand-text);}
  .pill.cat-mandatory::before{background:var(--cat-mand-dot);}
  .pill.cat-language{background:var(--cat-lang-bg);color:var(--cat-lang-text);}
  .pill.cat-language::before{background:var(--cat-lang-dot);}
  .pill.cat-soft-skills{background:var(--cat-soft-bg);color:var(--cat-soft-text);}
  .pill.cat-soft-skills::before{background:var(--cat-soft-dot);}
  .lock{margin-left:auto;font-size:9px;opacity:.7;}
  .more-tag{font-size:10px;color:var(--gray-500);padding:0 4px;}

  .modal-backdrop{position:fixed;inset:0;background:rgba(10,37,64,.5);z-index:100;display:none;align-items:flex-start;justify-content:center;padding:24px;overflow-y:auto;}
  .modal-backdrop.show{display:flex;}
  .modal{background:#fff;border-radius:16px;width:100%;max-width:720px;box-shadow:var(--shadow-lg);margin:auto;animation:slideIn .25s ease;}
  .modal.sm{max-width:440px;}
  @keyframes slideIn{from{opacity:0;transform:translateY(-20px);}to{opacity:1;transform:translateY(0);}}
  .modal-head{padding:20px 24px;border-bottom:1px solid var(--gray-200);display:flex;justify-content:space-between;align-items:center;}
  .modal-head h3{font-size:18px;font-weight:600;}
  .modal-close{background:transparent;font-size:24px;color:var(--gray-500);width:32px;height:32px;border-radius:8px;transition:.2s;}
  .modal-close:hover{background:var(--gray-100);}
  .modal-body{padding:24px;max-height:calc(100vh - 200px);overflow-y:auto;}
  .modal-foot{padding:16px 24px;border-top:1px solid var(--gray-200);display:flex;justify-content:flex-end;gap:10px;}
  .btn-secondary{background:var(--gray-100);color:var(--navy);padding:10px 18px;border-radius:8px;font-weight:500;font-size:13px;transition:.2s;}
  .btn-secondary:hover{background:var(--gray-200);}
  .btn-danger{background:#FEE2E2;color:var(--red);padding:10px 18px;border-radius:8px;font-weight:500;font-size:13px;transition:.2s;}
  .btn-danger:hover{background:#FECACA;}
  .btn-sm{padding:6px 12px;font-size:12px;}

  .form-group{margin-bottom:18px;}
  .form-group label.lbl{display:block;font-size:13px;font-weight:500;color:var(--navy);margin-bottom:6px;}
  .form-group .req{color:var(--red);}
  .form-group .hint{font-size:11px;color:var(--gray-500);margin-top:4px;}
  .form-group input[type=text],
  .form-group input[type=number],
  .form-group input[type=url],
  .form-group input[type=month],
  .form-group textarea{width:100%;padding:10px 12px;border:1px solid var(--gray-200);border-radius:8px;transition:.2s;}
  .form-group input:focus,.form-group textarea:focus{outline:none;border-color:var(--teal);box-shadow:0 0 0 3px rgba(20,184,166,.12);}
  .checkbox-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
  .check-item,.radio-item{display:flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid var(--gray-200);border-radius:8px;cursor:pointer;transition:.15s;font-size:13px;}
  .check-item:hover,.radio-item:hover{background:var(--gray-50);}
  .check-item input,.radio-item input{margin:0;cursor:pointer;}
  .radio-stack{display:flex;flex-direction:column;gap:8px;}
  .branching{margin-top:8px;padding-left:12px;border-left:2px solid var(--teal);}

  .cat-radio-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
  .cat-radio{display:flex;align-items:center;gap:8px;padding:10px 12px;border:1px solid var(--gray-200);border-radius:8px;cursor:pointer;font-size:13px;transition:.15s;}
  .cat-radio:hover{background:var(--gray-50);}
  .cat-radio input{margin:0;}
  .cat-radio .swatch{width:14px;height:14px;border-radius:4px;}

  /* ===== COMPACT mini calendar (v3.1) ===== */
  .mini-cal{border:1px solid var(--gray-200);border-radius:10px;padding:10px;background:#fff;max-width:340px;}
  .mini-cal-nav{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
  .mini-cal-nav h4{font-size:12px;font-weight:600;color:var(--navy);}
  .mini-cal-nav button{background:var(--gray-100);width:24px;height:24px;border-radius:6px;font-size:12px;color:var(--navy);}
  .mini-cal-nav button:hover{background:var(--gray-200);}
  .mini-cal-head{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:2px;}
  .mini-cal-head>div{text-align:center;font-size:9px;color:var(--gray-500);font-weight:600;padding:2px 0;text-transform:uppercase;}
  .mini-cal-head>div.we{color:var(--teal);}
  .mini-cal-body{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
  .mini-day{height:28px;display:flex;align-items:center;justify-content:center;border-radius:6px;font-size:11px;font-weight:500;cursor:pointer;transition:.15s;user-select:none;color:var(--navy);background:var(--gray-50);}
  .mini-day:hover{background:var(--gray-200);}
  .mini-day.other{color:var(--gray-300);background:transparent;cursor:default;}
  .mini-day.other:hover{background:transparent;}
  .mini-day.we:not(.other){color:var(--teal);}
  .mini-day.selected{background:var(--teal)!important;color:#fff!important;}
  .mini-summary{margin-top:10px;font-size:11px;color:var(--gray-500);padding:8px;background:var(--gray-50);border-radius:8px;line-height:1.55;}
  .mini-summary b{color:var(--navy);}
  .mini-summary .month-line{display:block;}
  .mini-summary .clear-btn{float:right;background:transparent;color:var(--red);font-size:10px;text-decoration:underline;cursor:pointer;padding:0;}

  .day-course{padding:14px;border:1px solid var(--gray-200);border-radius:10px;margin-bottom:10px;}
  .day-course-head{display:flex;justify-content:space-between;align-items:start;gap:10px;margin-bottom:8px;flex-wrap:wrap;}
  .day-course-title{font-weight:600;font-size:14px;flex:1;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
  .day-course-meta{font-size:12px;color:var(--gray-500);line-height:1.7;}
  .badge{display:inline-block;padding:2px 8px;border-radius:5px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;}
  .badge.cat-technical{background:var(--cat-tech-bg);color:var(--cat-tech-text);}
  .badge.cat-mandatory{background:var(--cat-mand-bg);color:var(--cat-mand-text);}
  .badge.cat-language{background:var(--cat-lang-bg);color:var(--cat-lang-text);}
  .badge.cat-soft-skills{background:var(--cat-soft-bg);color:var(--cat-soft-text);}
  .badge-public{background:var(--teal-light);color:var(--teal-dark);}
  .badge-internal{background:#FEF3C7;color:#92400E;}
  .day-course-actions{display:flex;gap:6px;margin-top:10px;}

  .export-option{display:block;padding:14px;border:1px solid var(--gray-200);border-radius:10px;margin-bottom:10px;cursor:pointer;transition:.15s;}
  .export-option:hover{border-color:var(--teal);background:var(--gray-50);}
  .export-option .title{font-weight:600;font-size:14px;margin-bottom:4px;}
  .export-option .desc{font-size:12px;color:var(--gray-500);}
  .export-option .range-inputs{display:none;margin-top:10px;grid-template-columns:1fr 1fr;gap:8px;}

  .toast{position:fixed;bottom:24px;right:24px;background:var(--navy);color:#fff;padding:14px 20px;border-radius:10px;box-shadow:var(--shadow-lg);z-index:200;font-size:13px;animation:slideUp .3s ease;}
  .toast.success{background:var(--green);}
  .toast.error{background:var(--red);}
  @keyframes slideUp{from{transform:translateY(20px);opacity:0;}to{transform:translateY(0);opacity:1;}}

  .empty{text-align:center;padding:40px 20px;color:var(--gray-500);font-size:14px;}
  .spinner{display:inline-block;width:18px;height:18px;border:2px solid var(--gray-200);border-top-color:var(--teal);border-radius:50%;animation:spin .8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}

  @media (max-width:768px){
    main.app{padding:14px;}
    .day{min-height:80px;padding:5px;}
    .daynum{width:22px;height:22px;font-size:12px;}
    .pill{font-size:10px;padding:2px 6px;}
    .month-nav h2{font-size:18px;min-width:130px;}
    .checkbox-grid,.cat-radio-grid{grid-template-columns:1fr;}
    .modal{margin:10px;}
    .modal-body{padding:16px;}
    .cal-head>div{font-size:10px;padding:8px 4px;}
  }
</style>
</head>
<body>

<div id="loginScreen" class="login-wrap">
  <div class="login-card">
    <div class="brand" style="margin-bottom:20px;">
      <div class="logo" style="background:var(--navy);color:#fff;">C</div>
      <div>
        <div style="font-size:14px;font-weight:600;">Coteccons Academy</div>
        <div class="sub" style="color:var(--gray-500);">Admin · Training Calendar</div>
      </div>
    </div>
    <h1>Đăng nhập</h1>
    <p class="lead">Truy cập trang quản trị lịch đào tạo</p>
    <form id="loginForm">
      <label>Email</label>
      <input type="email" id="loginEmail" required placeholder="ten@coteccons.vn" autocomplete="email"/>
      <label>Mật khẩu</label>
      <input type="password" id="loginPassword" required placeholder="••••••••" autocomplete="current-password"/>
      <button class="btn-primary" type="submit" id="loginBtn">Đăng nhập</button>
      <div class="err" id="loginErr"></div>
    </form>
  </div>
</div>

<header class="topbar" id="topbar" style="display:none;">
  <div class="brand">
    <div class="logo">C</div>
    <div>
      <div>Coteccons Academy</div>
      <div class="sub">Admin · Training Calendar</div>
    </div>
  </div>
  <div class="user-info">
    <span class="email" id="userEmail">—</span>
    <button class="btn-logout" id="btnLogout">Đăng xuất</button>
  </div>
</header>

<main class="app" id="app">
  <div class="toolbar">
    <div class="toolbar-left">
      <div class="month-nav">
        <button class="nav-btn" id="prevMonth">‹</button>
        <h2 id="monthLabel">—</h2>
        <button class="nav-btn" id="nextMonth">›</button>
      </div>
      <div class="filter-pills">
        <button data-filter="all" class="active">Tất cả</button>
        <button data-filter="public">🌐 Công khai</button>
        <button data-filter="internal">🔒 Nội bộ</button>
      </div>
    </div>
    <div class="toolbar-right">
      <button class="btn-export" id="btnExport">📊 Export Excel</button>
    </div>
  </div>

  <div class="calendar">
    <div class="cal-head">
      <div>T2</div><div>T3</div><div>T4</div><div>T5</div><div>T6</div>
      <div class="weekend">T7</div><div class="weekend">CN</div>
    </div>
    <div class="cal-body" id="calBody"></div>
  </div>
</main>

<div class="modal-backdrop" id="dayModal">
  <div class="modal">
    <div class="modal-head">
      <h3 id="dayModalTitle">Ngày —</h3>
      <button class="modal-close" data-close>×</button>
    </div>
    <div class="modal-body" id="dayModalBody"></div>
    <div class="modal-foot">
      <button class="btn-secondary" data-close>Đóng</button>
      <button class="btn-primary" id="btnAddCourse" style="width:auto;">+ Thêm khoá học</button>
    </div>
  </div>
</div>

<div class="modal-backdrop" id="formModal">
  <div class="modal">
    <div class="modal-head">
      <h3 id="formTitle">Thêm khoá học</h3>
      <button class="modal-close" data-close>×</button>
    </div>
    <form id="courseForm">
      <div class="modal-body">

        <div class="form-group">
          <label class="lbl">1. Tên khoá học <span class="req">*</span></label>
          <input type="text" name="name" required maxlength="200"/>
        </div>

        <div class="form-group">
          <label class="lbl">2. Tên ngắn</label>
          <input type="text" name="short_name" maxlength="40" placeholder="Hiển thị trong ô lịch nếu tên gốc quá dài"/>
          <div class="hint">Tối đa ~30 ký tự để hiển thị gọn trong calendar.</div>
        </div>

        <div class="form-group">
          <label class="lbl">3. Phân loại <span class="req">*</span></label>
          <div class="cat-radio-grid">
            <label class="cat-radio"><input type="radio" name="category" value="technical" required/><span class="swatch" style="background:var(--cat-tech-dot)"></span><span>Technical</span></label>
            <label class="cat-radio"><input type="radio" name="category" value="mandatory"/><span class="swatch" style="background:var(--cat-mand-dot)"></span><span>Mandatory</span></label>
            <label class="cat-radio"><input type="radio" name="category" value="language"/><span class="swatch" style="background:var(--cat-lang-dot)"></span><span>Language</span></label>
            <label class="cat-radio"><input type="radio" name="category" value="soft-skills"/><span class="swatch" style="background:var(--cat-soft-dot)"></span><span>Soft-skills</span></label>
          </div>
        </div>

        <div class="form-group">
          <label class="lbl">4. Hình thức <span class="req">*</span></label>
          <div class="checkbox-grid">
            <label class="check-item"><input type="checkbox" name="formats" value="Online"/> Online</label>
            <label class="check-item"><input type="checkbox" name="formats" value="Trực tiếp HCM"/> Trực tiếp HCM</label>
            <label class="check-item"><input type="checkbox" name="formats" value="Trực tiếp HN"/> Trực tiếp HN</label>
            <label class="check-item"><input type="checkbox" name="formats" value="Trực tiếp ĐN"/> Trực tiếp ĐN</label>
            <label class="check-item"><input type="checkbox" name="formats" value="Trực tiếp PQ"/> Trực tiếp PQ</label>
            <label class="check-item"><input type="checkbox" name="formats" value="E-learning"/> E-learning</label>
          </div>
        </div>

        <div class="form-group">
          <label class="lbl">5. Đối tượng <span class="req">*</span></label>
          <input type="text" name="target" required placeholder="VD: Trưởng phòng & Phó phòng"/>
        </div>

        <div class="form-group">
          <label class="lbl">6. Giảng viên <span class="req">*</span></label>
          <div class="radio-stack">
            <label class="radio-item"><input type="radio" name="trainer_type" value="internal" required/> Nội bộ</label>
            <div class="branching" id="branchTrainerInt" style="display:none;">
              <input type="text" name="trainer_name_internal" placeholder="Tên giảng viên nội bộ..."/>
            </div>
            <label class="radio-item"><input type="radio" name="trainer_type" value="external"/> Bên ngoài</label>
            <div class="branching" id="branchTrainerExt" style="display:none;">
              <input type="text" name="trainer_name_external" placeholder="Tên giảng viên / đối tác bên ngoài..."/>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label class="lbl">7. Thời lượng (giờ) <span class="req">*</span></label>
