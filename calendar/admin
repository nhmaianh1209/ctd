async function api_signIn(email, pwd){ return signInWithEmailAndPassword(auth, email, pwd); }
async function api_signOut(){ return signOut(auth); }
function api_onAuthChange(cb){ return onAuthStateChanged(auth, cb); }
function api_currentUserEmail(){ return auth.currentUser ? auth.currentUser.email : null; }

async function api_loadCoursesByMonth(yearMonth){
  const q = query(collection(db,'courses'), where('months','array-contains', yearMonth));
  const snap = await getDocs(q);
  return snap.docs.map(d=>({id:d.id,...d.data()}));
}
async function api_loadAllCourses(){
  const snap = await getDocs(collection(db,'courses'));
  return snap.docs.map(d=>({id:d.id,...d.data()}));
}
async function api_loadCoursesByMonthRange(startYM, endYM){
  const months = listMonthsBetween(startYM, endYM);
  const results = new Map();
  for(const m of months){
    const list = await api_loadCoursesByMonth(m);
    list.forEach(c=>results.set(c.id, c));
  }
  return [...results.values()];
}
async function api_createCourse(data){
  data.created_by = api_currentUserEmail();
  data.created_at = serverTimestamp();
  data.updated_by = data.created_by;
  data.updated_at = serverTimestamp();
  return addDoc(collection(db,'courses'), data);
}
async function api_updateCourse(id, data){
  data.updated_by = api_currentUserEmail();
  data.updated_at = serverTimestamp();
  return updateDoc(doc(db,'courses',id), data);
}
async function api_deleteCourse(id){
  return deleteDoc(doc(db,'courses',id));
}
/* ===== END BACKEND ADAPTER LAYER ===== */

const today = new Date();
let currentYear = today.getFullYear();
let currentMonth = today.getMonth();
let filterMode = 'all';
let monthCourses = [];
let selectedDay = null;
let selectedDates = [];
let miniYear = currentYear;
let miniMonth = currentMonth;
const MONTHS_VI = ['Tháng 1','Tháng 2','Tháng 3','Tháng 4','Tháng 5','Tháng 6','Tháng 7','Tháng 8','Tháng 9','Tháng 10','Tháng 11','Tháng 12'];

function pad2(n){ return String(n).padStart(2,'0'); }
function toISO(y,m,d){ return `${y}-${pad2(m+1)}-${pad2(d)}`; }
function toYM(y,m){ return `${y}-${pad2(m+1)}`; }
function parseISO(s){ const [y,m,d]=s.split('-').map(Number); return {y,m:m-1,d}; }
function esc(s){
  return (s||'').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function categoryLabel(cat){
  return {technical:'Technical', mandatory:'Mandatory', language:'Language', 'soft-skills':'Soft-skills'}[cat]||cat;
}
function formatDatesGrouped(dates){
  if(!dates || dates.length===0) return '—';
  const sorted = dates.slice().sort();
  const parts = sorted.map((iso,i)=>{
    const {y,m,d} = parseISO(iso);
    const dd = pad2(d), mm = pad2(m+1);
    const isLast = (i===sorted.length-1);
    return isLast ? `${dd}/${mm}/${y}` : `${dd}/${mm}`;
  });
  return parts.join(', ');
}

function listMonthsBetween(ymStart, ymEnd){
  const [y1,m1] = ymStart.split('-').map(Number);
  const [y2,m2] = ymEnd.split('-').map(Number);
  const out = [];
  let y=y1, m=m1;
  while(y<y2 || (y===y2 && m<=m2)){
    out.push(`${y}-${pad2(m)}`);
    m++; if(m>12){m=1;y++;}
  }
  return out;
}

